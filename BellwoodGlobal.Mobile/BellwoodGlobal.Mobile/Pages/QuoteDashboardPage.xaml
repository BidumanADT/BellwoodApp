<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BellwoodGlobal.Mobile.Pages.QuoteDashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource BellwoodInk}"
    Title="Quote Dashboard">

	<ContentPage.ToolbarItems>
		<ToolbarItem Text="Back" Priority="0" Order="Primary" Clicked="OnBackClicked" />
		<ToolbarItem Text="Logout" Priority="1" Order="Primary" Clicked="OnLogoutClicked" />
	</ContentPage.ToolbarItems>

	<Grid RowDefinitions="Auto,Auto,Auto,*" Padding="16" RowSpacing="10">
		<!-- Filter buttons -->
		<HorizontalStackLayout Grid.Row="0" Spacing="8">
			<Button x:Name="AllBtn" Text="All" Clicked="OnFilterClicked" />
			<Button x:Name="AwaitingBtn" Text="Awaiting Response" Clicked="OnFilterClicked" />
			<Button x:Name="RespondedBtn" Text="Response Received" Clicked="OnFilterClicked" />
			<Button x:Name="CancelledBtn" Text="Cancelled" Clicked="OnFilterClicked" />
		</HorizontalStackLayout>

		<!-- Search -->
		<Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="8">
			<Label Text="Search" VerticalOptions="Center" TextColor="{StaticResource BellwoodCream}" />
			<Entry Grid.Column="1"
                   x:Name="SearchEntry"
                   Placeholder="ID, passenger, or pickup…"
                   TextColor="{StaticResource BellwoodCream}"
                   BackgroundColor="{StaticResource BellwoodCharcoal}"
                   TextChanged="OnSearchChanged"/>
		</Grid>

		<!-- Phase Alpha: Status Change Notification Banner -->
		<Frame x:Name="NotificationBanner"
		       Grid.Row="2"
		       Padding="12,8"
		       CornerRadius="8"
		       BackgroundColor="{StaticResource BellwoodGold}"
		       IsVisible="False"
		       Margin="0,0,0,4">
			<Grid ColumnDefinitions="Auto,*,Auto">
				<Label Grid.Column="0"
				       Text="✓"
				       FontSize="18"
				       FontAttributes="Bold"
				       TextColor="{StaticResource BellwoodInk}"
				       VerticalOptions="Center"
				       Margin="0,0,8,0" />
				<Label x:Name="NotificationMessage"
				       Grid.Column="1"
				       Text="Quote status updated"
				       TextColor="{StaticResource BellwoodInk}"
				       FontAttributes="Bold"
				       VerticalOptions="Center" />
				<Label Grid.Column="2"
				       Text="✕"
				       FontSize="16"
				       TextColor="{StaticResource BellwoodInk}"
				       VerticalOptions="Center">
					<Label.GestureRecognizers>
						<TapGestureRecognizer Tapped="OnDismissNotification" />
					</Label.GestureRecognizers>
				</Label>
			</Grid>
		</Frame>

		<!-- List -->
		<RefreshView Grid.Row="3" x:Name="Refresh" Refreshing="OnRefresh">
			<CollectionView x:Name="List"
                            SelectionMode="Single"
                            SelectionChanged="OnSelectionChanged"
                            ItemsLayout="VerticalList">
				<CollectionView.ItemTemplate>
					<DataTemplate>
						<Grid Padding="12" Margin="0,6"
                              BackgroundColor="{StaticResource BellwoodCharcoal}"
                              ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto,Auto">
							<!-- Title (Passenger · Vehicle) -->
							<Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Title}"
                                   TextColor="{StaticResource BellwoodCream}"
                                   FontAttributes="Bold" />
							<!-- Status chip -->
							<Frame Grid.Row="0" Grid.Column="1"
                                   Padding="8,4" CornerRadius="10" HasShadow="False"
                                   BackgroundColor="{Binding StatusColor}">
								<Label Text="{Binding Status}"
                                       TextColor="{StaticResource BellwoodInk}"
                                       FontAttributes="Bold" />
							</Frame>

							<!-- SubTitle (pickup dt + location) -->
							<Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="{Binding SubTitle}"
                                   TextColor="{StaticResource BellwoodCream}"
                                   Opacity="0.9" FontSize="12"/>

							<!-- Meta (booker • drop • created) -->
							<Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="{Binding Meta}"
                                   TextColor="{StaticResource BellwoodCream}"
                                   Opacity="0.7" FontSize="12"/>
						</Grid>
					</DataTemplate>
				</CollectionView.ItemTemplate>
			</CollectionView>
		</RefreshView>
	</Grid>
</ContentPage>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
    iOS Entitlements for BellwoodGlobal.Mobile
    ============================================
    These entitlements MUST match the capabilities enabled on the App ID
    (com.bellwoodglobal.mobile) in Apple Developer and the provisioning
    profile used for distribution (BWEliteAppStoreProfile).

    If the entitlements here do not align with the provisioning profile,
    codesign produces an invalid entitlements blob and iOS will terminate
    the app immediately on launch — with NO crash log.

    This file is only used for Release builds (see CodesignEntitlements
    in the .csproj).  Debug/Simulator builds omit it intentionally.
-->
<dict>
    <!-- Push Notifications (APNs) — matches aps-environment in provisioning profile.
         Use "production" for TestFlight and App Store distribution. -->
    <key>aps-environment</key>
    <string>production</string>

    <!-- Location Push Service — enabled on the App ID / provisioning profile.
         Required even if not yet used by app code; omitting it when the profile
         declares it causes an entitlement mismatch at launch. -->
    <key>com.apple.developer.location.push</key>
    <true/>

    <!-- Keychain Access Groups — required for MAUI SecureStorage (iOS Keychain).
         The $(AppIdentifierPrefix) token is replaced at build time with the
         Team ID prefix (MRN263A5QW.). The wildcard entry covers the app's
         default keychain group.  com.apple.token is the system token group
         included in the provisioning profile. -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.bellwoodglobal.mobile</string>
        <string>com.apple.token</string>
    </array>
</dict>
</plist>
